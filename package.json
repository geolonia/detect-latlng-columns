{
  "name": "@geolonia/detect-latlng-columns",
  "version": "0.1.0",
  "description": "CSV/Excel のヘッダー名から緯度・経度カラムを判定・検出する依存ゼロの純粋関数。地理空間データ連携基盤の app/api で判定ロジックを共有する。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geolonia/detect-latlng-columns.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
